{
  "name": "@d31ma/chex",
  "version": "26.18.27",
  "description": "Regex-driven JSON schema validation and TypeScript declaration generation for Bun",
  "main": "./src/index.js",
  "types": "./types/index.d.ts",
  "type": "module",
  "bin": {
    "chex.generate": "./src/cli/generate-declarations.js"
  },
  "files": [
    "src/",
    "types/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "bun test ./tests/",
    "test:watch": "bun test --watch ./tests/",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepublishOnly": "bun run build && bun test ./tests/"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d31ma/CHEX.git"
  },
  "homepage": "https://github.com/d31ma/CHEX#readme",
  "bugs": {
    "url": "https://github.com/d31ma/CHEX/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "license": "MIT",
  "keywords": [
    "javascript",
    "bun",
    "validation",
    "schema",
    "regex",
    "typescript",
    "declarations"
  ],
  "author": "Chidelma",
  "devDependencies": {
    "@types/bun": "^1.2.19",
    "typescript": "^5.9.2"
  }
}
