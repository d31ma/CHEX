{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./types",
    "rootDir": "./src",
    "moduleResolution": "bundler",
    "target": "esnext",
    "module": "esnext",
    "strict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "types": ["bun-types"]
  },
  "include": ["src/**/*.js"],
  "exclude": ["node_modules", "tests", "types", "graphify-out"]
}
