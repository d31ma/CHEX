{
    "name": "^[A-Za-z]+ [A-Za-z]+$",
    "age": "^[0-9]+$",
    "active": "^(true|false)$",
    "nickname?": "^[a-zA-Z0-9_]+$",
    "address": {
        "city": "^[A-Za-z]+$",
        "country": "^[A-Za-z]+$"
    },
    "tags": ["^[a-z]+$"],
    "scores": ["^-?[0-9]+(\\.[0-9]+)?$"],
    "meta": { "^[a-zA-Z_]+$": "^.+$" }
}